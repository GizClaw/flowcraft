# FlowCraft Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Required
# ===================

# API authentication key (required for production)
FLOWCRAFT_AUTH_API_KEY=your-secret-api-key-here

# ===================
# Server Configuration
# ===================

# Server port (default: 8080)
FLOWCRAFT_SERVER_PORT=8080

# ===================
# Logging
# ===================

# Log level: debug, info, warn, error (default: info)
FLOWCRAFT_LOG_LEVEL=info

# Log format: text, json (default: text)
FLOWCRAFT_LOG_FORMAT=text

# ===================
# Sandbox Configuration
# ===================

# Sandbox driver: local, docker (default: local)
# Set to "docker" and run: docker compose --profile sandbox up
FLOWCRAFT_SANDBOX_DRIVER=local

# Sandbox mode: ephemeral, session, persistent (default: session)
FLOWCRAFT_SANDBOX_MODE=session

# Sandbox network mode: none, bridge, host (default: none)
# Set to "bridge" if skills need external network access (e.g. HTTP requests)
FLOWCRAFT_SANDBOX_NETWORK_MODE=none

# Host data directory for sandbox bind mounts (bare-metal only)
# When running FlowCraft directly on the host (not in Docker),
# this is the host path that maps to the workspace root.
# Leave empty to auto-detect from FLOWCRAFT_SANDBOX_ROOT_DIR.
# FLOWCRAFT_SANDBOX_HOST_DATA_DIR=

# ===================
# Telemetry (Optional)
# ===================

# Enable OpenTelemetry (default: false)
FLOWCRAFT_TELEMETRY_ENABLED=false

# OTLP endpoint (e.g., localhost:4317)
FLOWCRAFT_TELEMETRY_ENDPOINT=

# Use insecure gRPC connection
FLOWCRAFT_TELEMETRY_INSECURE=false

# ===================
# Webhook Integration (Optional)
# ===================

# Default app ID for webhooks
# FLOWCRAFT_WEBHOOK_DEFAULT_APP_ID=

# Slack
# FLOWCRAFT_WEBHOOK_SLACK_SIGNING_SECRET=
# FLOWCRAFT_WEBHOOK_SLACK_BOT_TOKEN=

# DingTalk
# FLOWCRAFT_WEBHOOK_DINGTALK_APP_SECRET=
# FLOWCRAFT_WEBHOOK_DINGTALK_WEBHOOK_URL=

# Feishu
# FLOWCRAFT_WEBHOOK_FEISHU_VERIFICATION_TOKEN=
# FLOWCRAFT_WEBHOOK_FEISHU_ENCRYPT_KEY=
# FLOWCRAFT_WEBHOOK_FEISHU_APP_ID=
# FLOWCRAFT_WEBHOOK_FEISHU_APP_SECRET=

# ===================
# LLM Provider Keys (for integration tests)
# ===================
# Fill in the providers you want to test. Leave blank to skip.

# Each provider is a single JSON env var: {"api_key":"...","model":"...","base_url":"...","caps":{"no_temperature":true}}
# Leave empty or omit to skip that provider in tests.

# MiniMax (Anthropic-compatible)
FLOWCRAFT_TEST_MINIMAX={"api_key":"","model":"MiniMax-M2.5"}

# Qwen (OpenAI-compatible, DashScope)
FLOWCRAFT_TEST_QWEN={"api_key":"","model":"qwen-flash"}

# ByteDance (Volcengine ArkRuntime)
FLOWCRAFT_TEST_BYTEDANCE={"api_key":"","model":"doubao-seed-1.6"}

# Azure OpenAI
FLOWCRAFT_TEST_AZURE={"api_key":"","model":"gpt-4o","base_url":"https://your-resource.openai.azure.com","caps":{"no_temperature":true}}

# DeepSeek (OpenAI-compatible)
FLOWCRAFT_TEST_DEEPSEEK={"api_key":"","model":"deepseek-chat"}

# ===================
# Voice pipeline example (examples/voice-pipeline)
# ===================
# Copy this file to deploy/.env (or repo-root .env) and fill values.
# The example loads ../../deploy/.env when run from examples/voice-pipeline.
#
# Required when running that example (from examples/voice-pipeline: go run .):
FLOWCRAFT_VOICE_BYTEDANCE_APP_ID=
FLOWCRAFT_VOICE_BYTEDANCE_ACCESS_TOKEN=
FLOWCRAFT_VOICE_MINIMAX_API_KEY=
#
# Optional — minimax model/voice when not set in react_agent.yaml `llm:`:
# FLOWCRAFT_VOICE_MINIMAX_MODEL=MiniMax-M2.5-highspeed
# FLOWCRAFT_VOICE_MINIMAX_VOICE_ID=male-qn-qingse
#
# If FLOWCRAFT_VOICE_MINIMAX_API_KEY is empty, the example falls back to
# api_key from FLOWCRAFT_TEST_MINIMAX JSON above. Model defaults similarly
# from FLOWCRAFT_VOICE_MINIMAX_MODEL or FLOWCRAFT_TEST_MINIMAX.model.

module github.com/GizClaw/flowcraft/eval

go 1.25.0

// `eval` is a workspace member (see ../go.work) — `github.com/GizClaw/
// flowcraft/sdk` and `.../sdkx` resolve to the monorepo HEAD.
// Keep eval tests in workspace mode so the simpleqa harness exercises the
// current SDK and adapter code.

require (
	github.com/GizClaw/flowcraft/sdk v0.4.4
	github.com/GizClaw/flowcraft/sdkx v0.3.9
	github.com/spf13/cobra v1.10.2

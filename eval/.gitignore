# Eval-local artifacts; not tracked.
#
# - locomo/data/        upstream LoCoMo / LongMemEval dumps + converted .jsonl
#                       (CC-BY but bulky; users fetch via cmd/fetch + cmd/convert-locomo)
# - locomo/results/     per-run report JSON written by cmd/eval
# - history/results/    per-run report JSON written by cmd/eval
# - compiled binaries from `go build ./locomo/cmd/...`
locomo/data/
locomo/results/
history/results/
locomo/cmd/*/convert-locomo
locomo/cmd/*/eval
locomo/cmd/*/compare
locomo/cmd/*/fetch
locomo/cmd/*/ingest
# `go build ./locomo/cmd/<x>` from eval/ drops the binary at eval/<x>.
/convert-locomo
/eval
/compare
/fetch
/ingest
